target/
*.swp
*.swo
.DS_Store
.idea/
.vscode/
*.orig
*.rej

# session transcripts (developer-local artifacts)
2026-*-*.txt

# straitjacket runtime state directories (per-run artifacts); scoped to subdirs so
# .straitjacket/bugs.json and .straitjacket/report-bug.config.json stay committable.
.straitjacket/*/

# dogfood bug ledger — kept local-only in THIS repo (the canonical copy lives in the
# primary checkout's working tree). Untracked to avoid per-branch ledger churn across the
# many dev worktrees. NOTE: this is a repo-local policy; the shipped report-bug contract
# still recommends CONSUMERS commit their .straitjacket/bugs.json.
.straitjacket/bugs.json

# cargo-mutants run output
mutants.out/

# local Claude Code state (worktrees, agent IDs, settings overrides)
.claude/
