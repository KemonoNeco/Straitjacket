#!/bin/sh
# Cross-platform launcher for the straightjacket CLI.
# Dispatches to the prebuilt binary matching the host OS/arch. Committed
# binaries are named straightjacket-<rust-target-triple>[.exe] and produced by
# .github/workflows/build-binaries.yml. This file is invoked both via PATH
# (bare `straightjacket` from the skills) and by an explicit
# ${CLAUDE_PLUGIN_ROOT}/bin/straightjacket path (hooks), so it must stay
# extensionless and executable, and must print nothing of its own to stdout
# (hooks read the dispatched binary's stdout as JSON).
set -e
dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

case "$(uname -s)" in
  Linux)  vendor_os="unknown-linux-gnu" ;;
  Darwin) vendor_os="apple-darwin" ;;
  *) echo "straightjacket: unsupported OS '$(uname -s)'" >&2; exit 1 ;;
esac

case "$(uname -m)" in
  x86_64|amd64)  cpu="x86_64" ;;
  arm64|aarch64) cpu="aarch64" ;;
  *) echo "straightjacket: unsupported arch '$(uname -m)'" >&2; exit 1 ;;
esac

bin="$dir/straightjacket-$cpu-$vendor_os"
if [ ! -e "$bin" ]; then
  echo "straightjacket: no prebuilt binary for $cpu-$vendor_os at $bin" >&2
  exit 127
elif [ ! -x "$bin" ]; then
  echo "straightjacket: prebuilt binary at $bin is not executable (try: chmod +x $bin)" >&2
  exit 127
fi

exec "$bin" "$@"
